# Backend REST API base URL (Backend team — Azkal/Akmal). See docs/API.md
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# File storage URL (360° photos, thumbnails, audio, etc.)
NEXT_PUBLIC_STORAGE_URL=http://localhost:8000/storage

# Force using local mock data (lib/mock) even if API_BASE_URL is set.
# Set to "true" while the backend endpoints aren't ready. Empty/false = use the real API.
NEXT_PUBLIC_USE_MOCK=true
