# Base URL REST API backend (tim Backend — Azkal/Akmal). Lihat docs/API.md
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# URL file storage (foto 360°, thumbnail, audio, dll)
NEXT_PUBLIC_STORAGE_URL=http://localhost:8000/storage

# Paksa pakai mock data lokal (lib/mock) walau API_BASE_URL terisi.
# Set "true" selama endpoint backend belum siap. Kosong/false = pakai API asli.
NEXT_PUBLIC_USE_MOCK=true
